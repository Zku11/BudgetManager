@model MonthlyReportViewModel

@{
	ViewData["Title"] = "Reporte Mensual";
	int previousYear = Model.Year - 1;
	int nextYear = Model.Year + 1;
	var montosResume = new MontosResumeViewModel()
	{
		Incomes = Model.Incomes,
		Expenses = Model.Expenses,
		Total = Model.Total
	};
}

<partial name="_Submenu" model="TransactionsSubmenu.Monthly"/>

<h4>
	Mostrando Transacciones de
	<a asp-route-year="@previousYear" class="btn">
		<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left-square" viewBox="0 0 16 16">
			<path fill-rule="evenodd" d="M15 2a1 1 0 0 0-1-1H2a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1zM0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2zm11.5 5.5a.5.5 0 0 1 0 1H5.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L5.707 7.5z" />
		</svg>
	</a>
	@Model.Year
	<a asp-route-year="@nextYear" class="btn">
		<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-right-square" viewBox="0 0 16 16">
			<path fill-rule="evenodd" d="M15 2a1 1 0 0 0-1-1H2a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1zM0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2zm4.5 5.5a.5.5 0 0 0 0 1h5.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3a.5.5 0 0 0 0-.708l-3-3a.5.5 0 1 0-.708.708L10.293 7.5z" />
		</svg>
	</a>
</h4>

<partial name="_MontosResume" model="@montosResume"/>

<table class="table fs-5">
	<thead>
		<tr class="bg-light">
			<th>Mes</th>
			<th class="text-end">Ingresos</th>
			<th class="text-end">Gastos</th>
		</tr>
	</thead>
	<tbody>
		@foreach(var transactionByMonth in Model.TransactionsByMonth){
			<tr>
				<td>
					<a asp-action="Index" asp-route-month="@transactionByMonth.Month" asp-route-year="@Model.Year">
						@transactionByMonth.ReferenceDate.ToString("MMM")
					</a>
				</td>
				<td class="active text-end">
					@transactionByMonth.Incomes
				</td>
				<td class="pasive text-end">
					@transactionByMonth.Expenses
				</td>
			</tr>
		}
	</tbody>
</table>