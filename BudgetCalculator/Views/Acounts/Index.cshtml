@model IEnumerable<AcountsIndexViewModel>

@{
	ViewData["Title"] = "Cuentas";

	string FormatBalance(decimal balance)
	{
		return Math.Abs(balance).ToString("N");
	}

	string ObtainBalanceClass(decimal balance)
	{
		return balance >= 0 ? "active" : "pasive";
	}
}

<h1>Cuentas</h1>


<a asp-action="CreateAcount" class="btn btn-primary mb-3">Crear nueva</a>

<div class="total-container mb-3">
	<div>
		<div>
			<strong>Activos</strong>
		</div>
		<div class="active">
			@FormatBalance(Model.Where(x => x.Balance > 0).Sum(x => x.Balance))
		</div>
		
	</div>
	<div>
		<div>
			<strong>Pasivos</strong>
		</div>
		<div class="pasive">
			@FormatBalance(Model.Where(x => x.Balance < 0).Sum(x => x.Balance))
		</div>
	</div>

	<div>
		<div>
			<strong>Total</strong>
		</div>
		<div>
			@FormatBalance(Model.Sum(x => x.Balance))
		</div>
	</div>
</div>

<div class="accordion">
	@foreach (var acountType in Model)
	{
		<div class="accordion-item">
			<h2 class="accordion-header" id="headerOne">
				@{
					var id = acountType.AcountType.Replace(" ", "");
					var dataTarget = "#" + id;
					var acountTypeClass = ObtainBalanceClass(acountType.Balance);
				}
				<button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="@dataTarget">
					<span class="me-3">
						<span><strong>@acountType.AcountType</strong></span>
						<span class="@acountTypeClass">@FormatBalance(acountType.Balance)</span>
					</span>
				</button>
			</h2>
			<div id="@id" class="accordion-collapse collapse show">
				<div>
					<ul class="list-group">
						@foreach (var acount in acountType.Acounts)
						{
							var AcountClass = ObtainBalanceClass(acount.Balance);
							<li class="list-group-item">
								<span>
									<strong><a asp-action="Detail" asp-route-id="@acount.Id">@acount.Name</a></strong>
									<a asp-action="Edit" asp-route-id="@acount.Id" class="btn btn-primary">
										<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil" viewBox="0 0 16 16">
											<path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325" />
										</svg>
									</a>
									<a asp-action="Delete" asp-route-id="@acount.Id" class="btn btn-danger">
										<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash-fill" viewBox="0 0 16 16">
											<path d="M2.5 1a1 1 0 0 0-1 1v1a1 1 0 0 0 1 1H3v9a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V4h.5a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H10a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1zm3 4a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-1 0v-7a.5.5 0 0 1 .5-.5M8 5a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-1 0v-7A.5.5 0 0 1 8 5m3 .5v7a.5.5 0 0 1-1 0v-7a.5.5 0 0 1 1 0" />
										</svg>
									</a>
									<strong>@acount.Name</strong>
								</span>
								<span class="@AcountClass">@FormatBalance(acount.Balance)</span>
							</li>
							
						}
					</ul>
				</div>
			</div>
		</div>
	}
</div>