@model IEnumerable<AcountType>;

@{
	ViewData["Title"] = "Listado de los tipos de cuentas por ID de usuario";
}

<h1>Cuentas por usuario</h1>

<a asp-action="Create" class="btn btn-primary mb-3">Crear nueva</a>

<table class="table">
	<thead>
		<tr>
			<th>Acciones</th>
			<th>Nombre</th>
		</tr>
	</thead>
	<tbody id="reorderable">
		@foreach (AcountType acountType in Model)
		{
			<tr>
				<td>
					<input type="hidden" value="@acountType.Id" class="ids"/>
					<a class="btn btn-primary" asp-action="Edit" asp-route-id="@acountType.Id">Editar</a>
					<a class="btn btn-danger" asp-action="Delete" asp-route-id="@acountType.Id">Borrar</a>
				</td>
				<td>
					@acountType.Name
				</td>
			</tr>
		}
	</tbody>
</table>

@section Scripts{
	<script>
		const orderURL = '@Url.Action("OrderTypes")';

		$(function(){
			$("#reorderable").sortable({
				stop: async function(e, ui){
					await UpdateOrder();
				}
			});

			async function UpdateOrder(){
				const ids = ObtainElementsIds();
				await SendIdsToBackend(ids);
			}

			function ObtainElementsIds(){
				const ids = $(".ids").map(function(){
					return $(this).val();
				}).get();
				return ids;
			}

			async function SendIdsToBackend(ids){
				let data = JSON.stringify(ids);
				await fetch(orderURL,
					{
						method: 'POST',
						body: data,
						headers: {'Content-Type':'application/json'}
					}
				);
			}
		})
	</script>
}
